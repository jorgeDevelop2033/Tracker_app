# ============================================================================
# Tracker — variables de entorno para el VPS (devsogu)
# Copia este archivo a `.env` y rellena los valores reales. NO commitear .env.
# Las claves usan __ (doble guion bajo) -> secciones de configuración .NET.
# ============================================================================

# Entorno ASP.NET (Production usa appsettings.Production.json si existe)
ASPNETCORE_ENVIRONMENT=Production

# ---- Base de datos: SQL Server compartido (devsogu-sqlserver) ----
# Host = nombre del contenedor SQL en devsogu-net. BD nueva: TrackerDb.
ConnectionStrings__TrackerDb=Server=devsogu-sqlserver,1433;Database=TrackerDb;User Id=sa;Password=CAMBIAR_PASSWORD_SA;TrustServerCertificate=True;

# ---- Kafka (broker interno del stack Tracker) ----
Kafka__BootstrapServers=tracker-kafka:9092
Kafka__Topic=tracker.gps.events
Kafka__GroupId=tracker.worker.gps
Kafka__ClientId=tracker.worker
SchemaRegistry__Url=http://tracker-schema-registry:8081

# ---- Broadcast en vivo: Worker -> API ----
# Dentro de la red, la API responde en su nombre de contenedor y puerto 8080.
LiveApi__BaseUrl=http://tracker-api:8080

# ---- Seguridad del endpoint interno /internal/* (compartida API + Worker) ----
InternalApi__Key=CAMBIAR_POR_KEY_LARGA_ALEATORIA

# ---- CORS de la API: orígenes del dashboard (separados por coma) ----
# Provisional por IP: el dashboard (tracker-web) se sirve en el puerto 8090.
Cors__AllowedOrigins=http://45.7.229.192:8090
